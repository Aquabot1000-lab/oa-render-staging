<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.overassessed.value-monitor</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>/Users/aquabot/Documents/OverAssessed/server/services/value-monitor.js</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/aquabot/Documents/OverAssessed/server</string>
    
    <!-- Run daily at 8:00 AM CT -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    
    <key>StandardOutPath</key>
    <string>/Users/aquabot/Documents/OverAssessed/server/logs/value-monitor.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/aquabot/Documents/OverAssessed/server/logs/value-monitor-error.log</string>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
